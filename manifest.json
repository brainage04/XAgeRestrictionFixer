{
  "manifest_version": 3,
  "name": "X Age Restriction Fixer",
  "description": "Fixes X's broken age-restricted media rendering for already age-verified accounts.",
  "version": "1.0.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "src/page-probe.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
